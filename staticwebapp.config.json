{
  "mimeTypes": {
    ".txt": "text/plain"
  },
  "routes": [
    {
      "route": "/.well-known/mta-sts.txt",
      "rewrite": "/mta-sts.txt",
      "headers": {
        "Cache-Control": "public, max-age=3600",
        "Content-Type": "text/plain; charset=utf-8"
      }
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/.well-known/*", "/mta-sts.txt"]
  }
}
